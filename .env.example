# --- Database -----------------------------------------------------------------
# Embedded (default): leave this line commented out. The API auto-starts
# an in-process PGlite database on first run. Zero setup needed.
#
# Docker:   docker compose up -d db
#           then set: postgresql://muxai_user:muxai_password@localhost:5432/muxai
#
# External: point to your own PostgreSQL instance
#           e.g.: postgresql://user:password@localhost:5432/muxai
#
DATABASE_URL=embedded

# --- API ----------------------------------------------------------------------
API_PORT=3001

# Protects all API endpoints. Use a long random string in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your-secret-key-change-me

# URL the Next.js frontend uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Internal secrets ---------------------------------------------------------
# Shared secret between the API and built-in MCP servers.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MUXAI_INTERNAL_SECRET=muxai-internal-secret-change-me

# Encryption key for agent wallet private keys (must be 64 hex chars / 32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=change-me-64-hex-chars

# --- Claude CLI ---------------------------------------------------------------
CLAUDE_CLI_PATH=claude
